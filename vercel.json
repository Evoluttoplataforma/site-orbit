{
  "outputDirectory": "site",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/blog/:slug", "destination": "/blog/leitor" },
    { "source": "/historias/:id", "destination": "/historias/historia" }
  ],
  "redirects": [
    { "source": "/pages/blog.html", "destination": "/blog", "statusCode": 301 },
    { "source": "/pages/historias.html", "destination": "/historias", "statusCode": 301 },
    { "source": "/pages/historias-enviar.html", "destination": "/historias/enviar", "statusCode": 301 },
    { "source": "/pages/processos.html", "destination": "/processos", "statusCode": 301 },
    { "source": "/pages/indicadores.html", "destination": "/indicadores", "statusCode": 301 },
    { "source": "/pages/tarefas.html", "destination": "/tarefas", "statusCode": 301 },
    { "source": "/pages/competencias.html", "destination": "/competencias", "statusCode": 301 },
    { "source": "/pages/auditorias.html", "destination": "/auditorias", "statusCode": 301 },
    { "source": "/pages/parcerias.html", "destination": "/parcerias", "statusCode": 301 },
    { "source": "/pages/obrigado.html", "destination": "/obrigado", "statusCode": 301 },
    { "source": "/blog/historia.html", "destination": "/historias", "statusCode": 301 }
  ]
}
